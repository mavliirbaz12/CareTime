{
  "name": "carevance-desktop",
  "version": "1.0.1",
  "description": "CareVance Tracker desktop timer and activity tracker",
  "private": true,
  "author": "CareVance",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist:win": "electron-builder --win nsis --config.win.artifactName=\"${productName}-Setup-${version}-${arch}.${ext}\"",
    "dist:portable": "electron-builder --win portable --config.win.artifactName=\"${productName}-Portable-${version}-${arch}.${ext}\""
  },
  "build": {
    "appId": "com.carevance.tracker",
    "productName": "CareVance Tracker",
    "icon": "assets/icon.ico",
    "files": [
      "main.cjs",
      "preload.cjs",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "asar": true,
    "npmRebuild": false,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CareVance Tracker",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "active-win": "^8.2.1"
  }
}
